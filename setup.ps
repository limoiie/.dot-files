Set-ExecutionPolicy unrestricted
Set-ExecutionPolicy -Scope Process -ExecutionPolicy Bypass

$DOT_FILES_ROOT=${HOME}\.dot-files
$DOT_CONFIG_HOME=${DOT_FILES_ROOT}\xdg-config
$XDG_CONFIG_HOME=${ENV:APPDATA}

% install system bins (rustup and cargo are now managed by mise, see xdg-config/mise/config.toml)
choco install -y 7zip git mise powertoys vscode

% install powershell modules
Install-Module -Name PSEverything,PSReadLine,ZLocation -Force -Confirm:$false

% configure powershell
New-Item -ItemType SymbolicLink -Path ${PROFILE} -Target ${DOT_CONFIG_HOME}\Microsoft.PowerShell_profile.ps1

% configure mise
New-Item -ItemType SymbolicLink -Path ${XDG_CONFIG_HOME}\mise -Target ${DOT_CONFIG_HOME}\mise

% install mise-managed tools (rust, go, ...)
mise install
